        <div class="hero-orb hero-orb-1"></div>
        <div class="hero-orb hero-orb-2"></div>
        <div class="hero-orb hero-orb-3"></div>
        <div class="hero-content">
            <MudIcon Icon="@Icons.Material.Filled.School" Size="Size.Large" Style="font-size: 3.5rem; color: rgba(255,255,255,0.85);" />
            <MudText Typo="Typo.h3" Style="color: white; font-weight: 800; margin-top: 14px; text-shadow: 0 2px 20px rgba(0,0,0,0.3); letter-spacing: -0.5px;">
