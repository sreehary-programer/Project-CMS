<MudDivider Class="my-4" />
<MudText Typo="Typo.caption" Align="Align.Center" Style="opacity: 0.5;" Class="pb-4">
    © 2026 BCA Academic Management System — Built  by Sreehary, Adith &amp; Theerthan
</MudText>

@code {



    // Stats counter fields
    private int animatedTables = 0;
    private int animatedRoles = 0;
    private int animatedModules = 0;
    private int animatedTech = 0;
    private const int TargetTables = 20;
    private const int TargetRoles = 7;
    private const int TargetModules = 10;
    private const int TargetTech = 6;
    private Timer? counterTimer;

    protected override async Task OnInitializedAsync()
    {


        StartCounterAnimation();
    }

    private void StartCounterAnimation()
    {
        counterTimer = new Timer(_ =>
        {
            bool done = true;
            if (animatedTables < TargetTables) { animatedTables++; done = false; }
            if (animatedRoles < TargetRoles) { animatedRoles++; done = false; }
            if (animatedModules < TargetModules) { animatedModules++; done = false; }
            if (animatedTech < TargetTech) { animatedTech++; done = false; }

            InvokeAsync(StateHasChanged);

            if (done)
            {
                counterTimer?.Dispose();
            }
        }, null, 300, 80);
    }

    private record TeamMember(string Name, string Initials, string Role, string Description, Color AvatarColor);

    private readonly List<TeamMember> teamMembers = new()
    {
       new("Sreehary", "S", "Full-Stack Developer",
    "Designed and implemented the overall AMS architecture within the CMS framework, " +
    "developed core academic modules including Student Management, Course Allocation, and Timetable Scheduling, " +
    "and handled database schema design with Entity Framework Core migrations.",
    Color.Primary),

new("Adith", "A", "Front-End & UI Developer",
    "Developed the academic dashboards using MudBlazor, structured navigation for AMS workflows, " +
    "implemented responsive layouts and theme management, and optimized user experience " +
    "for student, faculty, and administrator academic interfaces.",
    Color.Secondary),

new("Theerthan", "T", "Back-End & API Developer",
    "Implemented the AMS service layer and RESTful API controllers, configured role-based access control " +
    "for academic operations, developed attendance evaluation logic, and managed authentication " +
    "and authorization using ASP.NET Core Identity.",
    Color.Tertiary)
    };


}