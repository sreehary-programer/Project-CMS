    //     if (book == null)
    //         return;
    //     var parameters = new DialogParameters
    //     {
    //         { "BookId", book.Id },
    //         { "BookTitle", book.Title }
    //     };
       
    //     var options = new DialogOptions
    //     {
    //         CloseButton = true,
    //         MaxWidth = MaxWidth.Small,
    //         FullWidth = true
    //     };

    //     var dialog = _serv.Show<BookIssueDialog>("Issue Book", parameters, options);
    //     var result = await dialog.Result;

    //     if (!result.Canceled)
    //     {
    //         _snackbar.Add("Book issued successfully", Severity.Success);

    //         await Books();   
    //         StateHasChanged();
    //     }
    
    // }

    private void Cancel()
    {
        _MudDialog.Close(DialogResult.Cancel());
    }
}