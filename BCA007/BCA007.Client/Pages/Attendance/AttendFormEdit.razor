                                    }
                                </MudSelect>
                            </MudItem>

                            <MudItem xs="12">
                                <MudSelect T="int?" @bind-Value="Model.Period4_DefId"
                                           Required="true"
                                           Label="Select Period4 Attendance"
                                           Variant="Variant.Outlined"
                                           Placeholder="Please Select Period4 Attendance"
                                           Adornment="Adornment.Start"
                                           AdornmentIcon="@Icons.Material.Filled.AddModerator"
                                           AdornmentColor="Color.Primary">
                                    @foreach (var _option in _defperiod)
                                    {
                                        <MudSelectItem Value="@_option.Id">@_option.Text</MudSelectItem>
                                    }
