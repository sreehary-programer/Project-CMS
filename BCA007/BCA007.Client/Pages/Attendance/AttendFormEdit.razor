                <!-- PERIOD 4 -->
                <MudItem xs="12" md="6">
                    <MudPaper Class="pa-4" Elevation="2">
                        <MudText Typo="Typo.subtitle1" Class="mb-2">Period 4</MudText>

                        <MudGrid Spacing="2">
                            <MudItem xs="12">
                                <MudSelect T="int?" @bind-Value="Model.Period4_StaffId"
                                           Required="true"
                                           Label="Select Period4 Staff"
                                           Variant="Variant.Outlined"
                                           Placeholder="Select Period4 Staff"
                                           Adornment="Adornment.Start"
                                           AdornmentIcon="@Icons.Material.Filled.AddModerator"
                                           AdornmentColor="Color.Primary">
                                    @foreach (var _option in _staff)
                                    {
