@using BCA007.Shared.Service.Attendance
@using BCA007.Shared.Service.Core
@inject ISnackbar _snackbar
@inject IAttendFormService _serv
@inject ILookupService _lookup
<MudDialog>
    <DialogContent>
        @*     <EditForm >
            <DataAnnotationsValidator /> *@
        <MudForm @ref="_form" Model="Model">

            <!-- ================= HEADER SECTION ================= -->
            <MudPaper Class="pa-4 mb-4" Elevation="1">
                <MudText Typo="Typo.h6" Class="mb-3">Class & Date</MudText>

                <MudGrid Spacing="3">
                    <MudItem xs="12" md="6">
                        <MudSelect T="int?" @bind-Value="Model.Class_Id"
                                   Required="true"
                                   Label="Select a Class"
                                   Variant="Variant.Outlined"
                                   Placeholder="Please Select Class"
                                   Adornment="Adornment.Start"
                                   AdornmentIcon="@Icons.Material.Filled.AddModerator"
                                   AdornmentColor="Color.Primary">
                            @foreach (var _option in _class)
                            {
                                <MudSelectItem Value="@_option.Id">@_option.Text</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudDatePicker @bind-Date="Model.Date"
                                       Label="Date"
                                       Variant="Variant.Outlined" />
                    </MudItem>
                </MudGrid>
            </MudPaper>


            <!-- ================= PERIOD SECTION ================= -->
            <MudText Typo="Typo.h6" Class="mb-3">Periods</MudText>

            <MudGrid Spacing="3">

                <!-- PERIOD 1 -->
                <MudItem xs="12" md="6">
                    <MudPaper Class="pa-4" Elevation="2">
                        <MudText Typo="Typo.subtitle1" Class="mb-2">Period 1</MudText>

                        <MudGrid Spacing="2">
                            <MudItem xs="12">
                                <MudSelect T="int?" @bind-Value="Model.Period1_StaffId"
                                           Required="true"
                                           Label="Select Period1 Staff"
                                           Variant="Variant.Outlined"
                                           Placeholder="Select Period1 Staff"
                                           Adornment="Adornment.Start"
                                           AdornmentIcon="@Icons.Material.Filled.AddModerator"
                                           AdornmentColor="Color.Primary">
                                    @foreach (var _option in _staff)
                                    {
                                        <MudSelectItem Value="@_option.Id">@_option.Text</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>

                            <MudItem xs="12">
                                <MudSelect T="int?" @bind-Value="Model.Period1_DefId"
                                           Required="true"
                                           Label="Select Period1 Attendance"
                                           Variant="Variant.Outlined"
                                           Placeholder="Please Select Period1 Attendance"
                                           Adornment="Adornment.Start"
                                           AdornmentIcon="@Icons.Material.Filled.AddModerator"
                                           AdornmentColor="Color.Primary">
                                    @foreach (var _option in _defperiod)
                                    {
                                        <MudSelectItem Value="@_option.Id">@_option.Text</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                        </MudGrid>
                    </MudPaper>
                </MudItem>


                <!-- PERIOD 2 -->
                <MudItem xs="12" md="6">
                    <MudPaper Class="pa-4" Elevation="2">
                        <MudText Typo="Typo.subtitle1" Class="mb-2">Period 2</MudText>

                        <MudGrid Spacing="2">
                            <MudItem xs="12">
                                <MudSelect T="int?" @bind-Value="Model.Period2_StaffId"
                                           Required="true"
                                           Label="Select Period2 Staff"
                                           Variant="Variant.Outlined"
                                           Placeholder="Select Period2 Staff"
                                           Adornment="Adornment.Start"
                                           AdornmentIcon="@Icons.Material.Filled.AddModerator"
                                           AdornmentColor="Color.Primary">
                                    @foreach (var _option in _staff)
                                    {
                                        <MudSelectItem Value="@_option.Id">@_option.Text</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>

                            <MudItem xs="12">
                                <MudSelect T="int?" @bind-Value="Model.Period2_DefId"
                                           Required="true"
                                           Label="Select Period2 Attendance"
                                           Variant="Variant.Outlined"
                                           Placeholder="Please Select Period2 Attendance"
                                           Adornment="Adornment.Start"
                                           AdornmentIcon="@Icons.Material.Filled.AddModerator"
                                           AdornmentColor="Color.Primary">
                                    @foreach (var _option in _defperiod)
                                    {
                                        <MudSelectItem Value="@_option.Id">@_option.Text</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                        </MudGrid>
                    </MudPaper>
                </MudItem>


                <!-- PERIOD 3 -->
                <MudItem xs="12" md="6">
                    <MudPaper Class="pa-4" Elevation="2">
                        <MudText Typo="Typo.subtitle1" Class="mb-2">Period 3</MudText>

                        <MudGrid Spacing="2">
                            <MudItem xs="12">
                                <MudSelect T="int?" @bind-Value="Model.Period3_StaffId"
                                           Required="true"
                                           Label="Select Period3 Staff"
                                           Variant="Variant.Outlined"
                                           Placeholder="Select Period3 Staff"
                                           Adornment="Adornment.Start"
                                           AdornmentIcon="@Icons.Material.Filled.AddModerator"
                                           AdornmentColor="Color.Primary">
                                    @foreach (var _option in _staff)
                                    {
                                        <MudSelectItem Value="@_option.Id">@_option.Text</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>

                            <MudItem xs="12">
                                <MudSelect T="int?" @bind-Value="Model.Period3_DefId"
                                           Required="true"
                                           Label="Select Period3 Attendance"
                                           Variant="Variant.Outlined"
                                           Placeholder="Please Select Period3 Attendance"
                                           Adornment="Adornment.Start"
                                           AdornmentIcon="@Icons.Material.Filled.AddModerator"
                                           AdornmentColor="Color.Primary">
                                    @foreach (var _option in _defperiod)
                                    {
