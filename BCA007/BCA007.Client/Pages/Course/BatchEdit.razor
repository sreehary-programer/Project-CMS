@inject ISnackbar _snackbar
@inject IBatchService _serv

<MudDialog>
    <DialogContent>
        @* <EditForm>
            <DataAnnotationsValidator /> *@
            <MudForm @ref="_form" Model="Model">

                <MudTextField Label="batch Name"
                              For="@(() => Model.Batch_Name)"
                              @bind-Value="Model.Batch_Name" />

                <MudTextField Label="Duration"
                              For="@(() => Model.Duration)"
                              @bind-Value="Model.Duration" />

            </MudForm>
            @if (!string.IsNullOrEmpty(_error))
            {
                <MudAlert Severity="Severity.Error" Dense Class="mt-2">
                    @_error
                </MudAlert>
            }
        @* </EditForm> *@
    </DialogContent>

    <DialogActions>
        <MudButton Color="@(Action == "Delete" ? Color.Error : Color.Success)"
                   Disabled="_loading"
                   OnClick="SaveAsync">
            @if (_loading)
            {
                <MudProgressCircular Indeterminate Size="Size.Small" />
            }
            else
            {
                @(Action == "Edit" ? "Update" : Action)

            }
        </MudButton>
        <MudButton OnClick="Cancel">
            Cancel
        </MudButton>
    </DialogActions>
</MudDialog>

@code {

    [Parameter]
    public BatchDto Model { get; set; } = new();
    [Parameter]
    public string Action { get; set; } = "";

    [CascadingParameter]
    private IMudDialogInstance _MudDialog { get; set; } = default!;

    private MudForm _form = default!;
    private bool _loading;
    private string? _error;

    private async Task SaveAsync()
    {
        _error = null;

        await _form.Validate();
        if (!_form.IsValid)
            return;

        _loading = true;

        try
        {
            if ((Model.Id == 0) || (Action == "Create"))
            {
                var created = await _serv.CreateAsync(Model);
                Model.Id = created.Id;
                _snackbar.Add("Batch created successfully", Severity.Success);
            }
            else if (Action == "Delete")
            {
                await _serv.DeleteAsync(Model.Id);
                _snackbar.Add("Batch deleted successfully", Severity.Success);
            }
            else
            {
                await _serv.UpdateAsync(Model);
                _snackbar.Add("Batch updated successfully", Severity.Success);
            }

            _MudDialog.Close(DialogResult.Ok(Model));
        }
        catch (InvalidOperationException ex)
        {
            _error = ex.Message;
            _snackbar.Add(ex.Message, Severity.Warning);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _snackbar.Add("Failed to save batch", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void Cancel()
    {
        _MudDialog.Close(DialogResult.Cancel());
    }
}
