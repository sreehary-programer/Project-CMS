@page "/course/batchlist"
@inject ISnackbar _snackbar
@inject IBatchService _serv
@inject IDialogService _dialog

<MudPaper Class="pa-0 mt-6">
     <AuthorizeView>
     <Authorized >
    <MudDataGrid Dense Hover Items="_batches" Loading="_loading"
                 QuickFilter="QuickFilter"
                 SortMode="SortMode.Multiple"
                 @ref="_grid">
        <ToolBarContent>
            <MudText Typo="Typo.h6">Batch List</MudText>
            <MudSpacer />
            <MudTextField @bind-Value="_searchString" Placeholder="Search" Adornment="Adornment.Start" Immediate="true"
                          AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
            <MudButtonGroup Color="Color.Primary" Size="Size.Small" Variant="Variant.Filled">
                <MudButton StartIcon="@Icons.Material.Filled.Add"
                           Color="Color.Primary" Size="Size.Small"
                           OnClick="CreateDetails">
                    Add
                </MudButton>
                <MudButton StartIcon="@Icons.Material.Filled.Refresh"
                           Color="Color.Primary" Size="Size.Small"
                           OnClick="OnRefresh">
                    Refresh
                </MudButton>
               @*  <MudButton StartIcon="@Icons.Material.Filled.Help"
                           Color="Color.Primary" Size="Size.Small"
                           OnClick="OnRefresh">
                    Help
                </MudButton> *@
            </MudButtonGroup>
        </ToolBarContent>

        <Columns>
            <PropertyColumn Property="x => x.Batch_Name" Title="Name" />
            <PropertyColumn Property="x => x.Duration" Title="Duration" />
            <TemplateColumn Title="Actions">
                <CellTemplate Context="row">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                   Color="Color.Primary" Size="Size.Small"
                                   OnClick="@(() => EditDetails(row.Item))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                   Color="Color.Error" Size="Size.Small"
                                   OnClick="@(() => DeleteDetails(row.Item))" />
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent>
            <MudDataGridPager PageSizeOptions="new int[] { 5, 10, 25, 100 }" />
        </PagerContent>
    </MudDataGrid>
        </Authorized>
    </AuthorizeView>
</MudPaper>

@code {
    private MudDataGrid<BatchDto> _grid;
    private List<BatchDto> _batches = new();

    private bool _loading;
    private string _searchString = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        OnRefresh();
    }

    private bool QuickFilter(BatchDto x)
    {
        if (string.IsNullOrWhiteSpace(_searchString))
            return true;

        return x.Id.ToString().Contains(_searchString, StringComparison.OrdinalIgnoreCase)
            || x.Duration.ToString().Contains(_searchString, StringComparison.OrdinalIgnoreCase)
            || x.Batch_Name.Contains(_searchString, StringComparison.OrdinalIgnoreCase);
    }

    private void OnSearch(string text)
    {
        _searchString = text;
        OnRefresh();
    }

    private async void OnRefresh()
    {
        try
        {
            _loading = true;
            _batches = await _serv.GetAllAsync();
            await _grid.ReloadServerData(); // keeps sort & page
        }
        catch (Exception ex)
        {
            _snackbar.Add(ex.Message, Severity.Success);
        }
        finally
        {
            _loading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task CreateDetails()
    {
        await OpenDetailsDialog(new BatchDto(), "Create");
    }

    private async Task EditDetails(BatchDto dto)
    {
        // IMPORTANT: pass a COPY
        await OpenDetailsDialog(new BatchDto
        {
            Id = dto.Id,
            Batch_Name = dto.Batch_Name,
            Duration = dto.Duration
        }, "Edit");
    }
    private async Task DeleteDetails(BatchDto dto)
    {
        await OpenDetailsDialog(new BatchDto
        {
            Id = dto.Id,
            Batch_Name = dto.Batch_Name,
            Duration = dto.Duration
        }, "Delete");
    }
    private async Task OpenDetailsDialog(BatchDto model, string action)
    {
        _loading = true;
        var parameters = new DialogParameters
        {
            ["Model"] = model,
            ["Action"] = action
        };
        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            BackdropClick = false
        };

        var dialog = await _dialog.ShowAsync<BatchEdit>(
           $"{action} Batch",
            parameters, options);

        var result = await dialog.Result;
        _loading = false;

        if (result == null)
            return;
        if (result.Canceled)
            return;
        if (result.Data == null)
            return;

        OnRefresh();
        await InvokeAsync(StateHasChanged);
    }
}
